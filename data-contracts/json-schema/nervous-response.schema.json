{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NervousSystemPredictResponse",
  "type": "object",
  "required": [
    "patient_id",
    "risk_band",
    "session_quality",
    "confidence",
    "tap_rate_hz",
    "tremor_hz",
    "amplitude_dropoff"
  ],
  "properties": {
    "patient_id": { "type": "string" },
    "risk_band": { "type": "string", "enum": ["low", "medium", "high"] },
    "session_quality": { "type": "string", "enum": ["good", "warning", "poor"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "tap_rate_hz": { "type": "number", "minimum": 0 },
    "tremor_hz": { "type": "number", "minimum": 0 },
    "amplitude_dropoff": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
