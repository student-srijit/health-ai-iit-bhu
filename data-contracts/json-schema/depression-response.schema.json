{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DepressionPredictResponse",
  "type": "object",
  "required": [
    "patient_id",
    "status",
    "depression_score",
    "risk_band",
    "modalities_used",
    "spoof_detected"
  ],
  "properties": {
    "patient_id": { "type": "string" },
    "status": { "type": "string", "enum": ["accepted", "blocked"] },
    "depression_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "risk_band": { "type": "string", "enum": ["low", "medium", "high"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "camera_sqi": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "spoof_detected": { "type": "boolean" },
    "error_message": { "type": ["string", "null"] },
    "modalities_used": {
      "type": "array",
      "items": { "type": "string", "enum": ["text", "audio", "video"] }
    }
  },
  "additionalProperties": false
}
