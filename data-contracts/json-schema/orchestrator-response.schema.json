{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OrchestratorSummaryResponse",
  "type": "object",
  "required": [
    "patient_id",
    "overall_risk",
    "summary",
    "next_actions",
    "modality_flags"
  ],
  "properties": {
    "patient_id": { "type": "string" },
    "overall_risk": { "type": "string", "enum": ["low", "medium", "high"] },
    "summary": { "type": "string" },
    "huatuo_prompt": { "type": "string" },
    "quality_caveat": { "type": ["string", "null"] },
    "modality_flags": {
      "type": "object",
      "required": ["camera_used", "kineticare_used", "ppg_used"],
      "properties": {
        "camera_used": { "type": "boolean" },
        "kineticare_used": { "type": "boolean" },
        "ppg_used": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
