{
  "name": "health-ai-iit-bhu",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "npm run setup:all && npm --prefix apps/web run build",
    "prepare:models": "python3 scripts/prepare_models.py",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:depression": "python3 -m uvicorn depression_service.main:app --app-dir services/depression-service/src --host 0.0.0.0 --port 8001",
    "dev:ppg": "python3 -m uvicorn ppg_service.main:app --app-dir services/ppg-service/src --host 0.0.0.0 --port 8002",
    "dev:orchestrator": "python3 -m uvicorn orchestrator_service.main:app --app-dir services/orchestrator-service/src --host 0.0.0.0 --port 8003",
    "dev:kineticare": "python3 -m uvicorn kineticare_service.main:app --app-dir services/kineticare-service/src --host 0.0.0.0 --port 8004",
    "dev:blood": "python3 -m uvicorn blood_service.main:app --app-dir services/blood-service/src --host 0.0.0.0 --port 8005",
    "dev:nervous": "python3 -m uvicorn nervous_service.main:app --app-dir services/nervous-service/src --host 0.0.0.0 --port 8006",
    "setup:backend": "python3 -m pip install -r requirements-backend.txt",
    "setup:web": "npm --prefix apps/web install",
    "setup:all": "npm run setup:backend && npm run setup:web && npm run prepare:models"
  },
  "dependencies": {
    "@studio-freight/lenis": "^1.0.42",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2"
  }
}
