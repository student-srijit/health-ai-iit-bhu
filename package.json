{
  "name": "health-ai-iit-bhu",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "npm run setup:all && npm --prefix apps/web run build",
    "prepare:models": "python scripts/prepare_models.py",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:depression": "python -m uvicorn depression_service.main:app --app-dir services/depression-service/src --host 0.0.0.0 --port 8001",
    "dev:ppg": "python -m uvicorn ppg_service.main:app --app-dir services/ppg-service/src --host 0.0.0.0 --port 8002",
    "dev:orchestrator": "python -m uvicorn orchestrator_service.main:app --app-dir services/orchestrator-service/src --host 0.0.0.0 --port 8003",
    "dev:kineticare": "python -m uvicorn kineticare_service.main:app --app-dir services/kineticare-service/src --host 0.0.0.0 --port 8004",
    "setup:backend": "python -m pip install -r requirements-backend.txt",
    "setup:web": "npm --prefix apps/web install",
    "setup:all": "npm run setup:backend && npm run setup:web && npm run prepare:models"
  }
}
